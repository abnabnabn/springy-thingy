# Explicit mapping: TSM will fetch the secret on the right and inject it into the env var on the left.
# If TSM is not installed, tf.sh parses this file to check that these exact env vars are provided manually.

# Standard Terraform Variables
TF_VAR_aws_region=springy.aws_region
TF_VAR_domain_name=springy.domain_name
TF_VAR_certificate_domain=springy.certificate_domain
TF_VAR_app_name=springy.appname

# Terraform Remote Backend Configuration
TF_BACKEND_KEY=springy.terraform.backend.key
TF_BACKEND_BUCKET=terraform.backend.bucket
TF_BACKEND_REGION=terraform.backend.region
TF_BACKEND_DYNAMODB_TABLE=terraform.backend.dynamodb_table
TF_BACKEND_ENCRYPT=terraform.backend.encrypt
